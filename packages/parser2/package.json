{
  "name": "@coopenomics/parser2",
  "version": "1.0.2",
  "description": "Universal EOSIO/Antelope SHiP-to-Redis blockchain indexer (parser)",
  "license": "MIT",
  "author": "Coopenomics contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/coopenomics/parser"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "parser2": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration"
  },
  "dependencies": {
    "@coopenomics/coopos-ship-reader": "workspace:*",
    "@wharfkit/antelope": "^1.2.0",
    "ajv": "^8.17.1",
    "commander": "^12.1.0",
    "ioredis": "^5.4.1",
    "p-queue": "^8.0.1",
    "pino": "^9.2.0",
    "pino-pretty": "^13.1.3",
    "piscina": "^4.6.1",
    "prom-client": "^15.1.3",
    "yaml": "^2.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "1.6.1",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
