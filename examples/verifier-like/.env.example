# Chain State History (SHiP) WebSocket endpoint
SHIP_URL=ws://your-eos-node:29999

# Human-readable chain identifier (used as Redis key segment)
CHAIN_ID=eos-mainnet

# Redis connection string — use env var for password, never hardcode
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379

# Subscription identifier — must be unique per consumer
SUB_ID=verifier
